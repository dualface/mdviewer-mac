{
  "name": "mdviewer-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --emptyOutDir && node scripts/fix-html.mjs"
  },
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "vite": "^8.1.0"
  },
  "overrides": {
    "mermaid": {
      "katex": "$katex"
    }
